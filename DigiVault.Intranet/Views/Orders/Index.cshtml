@model List<DigiVault.Intranet.Models.AdminOrderDto>
@{
    ViewData["Title"] = "Orders";
    Layout = "_Layout";
    var page = (int)(ViewData["Page"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var dateFrom = ViewData["DateFrom"] as string;
    var dateTo = ViewData["DateTo"] as string;
}

@* FILTRY *@
<form method="get" class="flex gap-3 mb-6 flex-wrap">
    <input type="date" name="dateFrom" value="@dateFrom" class="input input-sm bg-black text-white border-gray-700 rounded-full" />
    <input type="date" name="dateTo" value="@dateTo" class="input input-sm bg-black text-white border-gray-700 rounded-full" />
    <button type="submit" class="btn btn-sm btn-ghost text-gray-400">Filter</button>
</form>

@* TABELA *@
<div class="card bg-black border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr class="text-gray-400 border-gray-800 bg-black">
                    <th>Order ID</th>
                    <th>User</th>
                    <th>Items</th>
                    <th>Total</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="text-gray-300">
                @foreach (var order in Model)
                {
                    <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                        <td class="font-mono text-xs text-gray-400">#@order.IdOrder</td>
                        <td>
                            <div>
                                <p class="text-white text-sm">@order.FullName</p>
                                <p class="text-gray-500 text-xs">@order.Email</p>
                            </div>
                        </td>
                        <td class="text-sm">@order.ItemsCount courses</td>
                        <td class="text-white font-bold text-sm">@order.TotalPrice.ToString("F2") PLN</td>
                        <td class="text-sm text-gray-500">@order.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a href="/orders/detail/@order.IdOrder" class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* PAGINACJA *@
@if (totalPages > 1)
{
    <div class="flex justify-center gap-2 mt-6">
        @for (int i = 1; i <= totalPages; i++)
        {
            <a href="?page=@i&dateFrom=@dateFrom&dateTo=@dateTo"
               class="btn btn-sm @(i == page ? "bg-white text-black" : "btn-ghost text-gray-400") rounded-full">
                @i
            </a>
        }
    </div>
}
