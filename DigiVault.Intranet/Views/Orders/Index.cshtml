                    <td class="font-mono text-xs text-gray-400">#1021</td>
                    <td>
                        <div>
                            <p class="text-white text-sm">Aleksandra Chełmińska</p>
                            <p class="text-gray-500 text-xs">aleksandra@example.com</p>
                        </div>
                    </td>
                    <td class="text-sm">2 courses</td>
                    <td class="text-white font-bold text-sm">299.98 PLN</td>
                    <td class="text-sm text-gray-500">25/03/2026</td>
                    <td>
                        <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                            <i class="fa fa-eye"></i>
                        </button>
                    </td>
