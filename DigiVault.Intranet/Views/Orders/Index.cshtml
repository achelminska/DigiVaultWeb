@{
    ViewData["Title"] = "Orders";
    Layout = "_Layout";
}

@* FILTRY *@
<div class="flex gap-3 mb-6 flex-wrap">
    <label class="input input-sm rounded-full bg-black border-gray-700 flex items-center gap-2 w-64">
        <svg class="h-4 w-4 opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
            </g>
        </svg>
        <input type="search" placeholder="Search orders..." class="bg-transparent text-white outline-none w-full text-sm" />
    </label>
    <input type="date" class="input input-sm bg-black text-white border-gray-700 rounded-full" />
    <input type="date" class="input input-sm bg-black text-white border-gray-700 rounded-full" />
</div>

@* TABELA *@
