@model DigiVault.Intranet.Models.AdminSettingsDto
@{
    ViewData["Title"] = "Settings";
    Layout = "_Layout";
    var commissionPercent = Model.CommissionRate * 100;
}

<div class="flex flex-col gap-6 max-w-2xl">

    @* PROWIZJA *@
    <div class="card bg-black border border-gray-800 rounded-xl p-6">
        <h2 class="text-white font-bold text-lg mb-4">Platform Commission</h2>
        <p class="text-gray-400 text-sm mb-4">Percentage taken from each course sale by the platform.</p>
        <form method="post" asp-action="Update" class="flex items-center gap-4">
            <input type="number" name="commissionRate" value="@commissionPercent.ToString("F0")" min="0" max="100"
                   class="input bg-black text-white border-gray-700 rounded-lg w-32" />
            <span class="text-gray-400">%</span>
            <button type="submit" class="btn bg-white text-black rounded-full btn-sm px-6 hover:bg-gray-200">
                Save
            </button>
        </form>
    </div>

    @* SALDO PLATFORMY *@
    <div class="card bg-black border border-gray-800 rounded-xl p-6">
        <h2 class="text-white font-bold text-lg mb-4">Platform Balance</h2>
        <p class="text-gray-400 text-sm mb-4">Total revenue collected by the platform from commissions.</p>
        <p class="text-white text-4xl font-bold">@Model.PlatformBalance.ToString("N2") PLN</p>
    </div>

</div>
