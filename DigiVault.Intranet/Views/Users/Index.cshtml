@model List<DigiVault.Intranet.Models.AdminUserDto>
@{
    ViewData["Title"] = "Users";
    Layout = "_Layout";
}

@* FILTRY *@
<div class="flex gap-3 mb-6 flex-wrap justify-between">
    <div class="flex gap-3 flex-wrap">
        <label class="input input-sm rounded-full bg-black border-gray-700 flex items-center gap-2 w-64">
            <svg class="h-4 w-4 opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </g>
            </svg>
            <input type="search" placeholder="Search users..." class="bg-transparent text-white outline-none w-full text-sm" />
        </label>
    </div>
    <button onclick="document.getElementById('modal-add-user').showModal()"
            class="btn bg-white text-black rounded-full btn-sm px-6 hover:bg-gray-200">
        + Add Worker
    </button>
</div>

@* TABELA *@
<div class="card bg-black border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr class="text-gray-400 border-gray-800 bg-black">
                    <th>ID</th>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Warnings</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="text-gray-300">
                @foreach (var user in Model)
                {
                    <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                        <td class="text-gray-500 text-sm font-mono">@user.IdUser</td>
                        <td>
                            <div class="flex items-center gap-3">
                                <div>
                                    <p class="text-white text-sm font-semibold">@user.FirstName @user.LastName</p>
                                </div>
                            </div>
                        </td>
                        <td class="text-sm">@user.Email</td>
                        <td>
                            @if (user.Role == "Worker")
                            {
                                <span class="badge badge-warning badge-sm rounded-lg">Worker</span>
                            }
                            else
                            {
                                <span class="badge bg-white text-black badge-sm rounded-lg">User</span>
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge badge-success badge-sm rounded-lg">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-error badge-sm rounded-lg">Banned</span>
                            }
                        </td>
                        <td class="text-center">@user.WarningsCount</td>
                        <td>
                            <div class="flex gap-2">
                                <a href="/users/detail/@user.IdUser"
                                   class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                    <i class="fa fa-eye"></i>
                                </a>
                                @if (user.IsActive)
                                {
                                    <form method="post" asp-action="SetNotActive" asp-route-id="@user.IdUser">
                                        <button type="submit" class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                            <i class="fa fa-ban"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-action="SetActive" asp-route-id="@user.IdUser">
                                        <button type="submit" class="btn btn-ghost btn-xs text-green-500 hover:text-green-400">
                                            <i class="fa fa-check"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* MODAL: ADD WORKER *@
<dialog id="modal-add-user" class="modal">
    <div class="modal-box bg-black border border-gray-800">
        <h3 class="text-white font-bold text-lg mb-4">Add Worker</h3>
        <form method="post" asp-action="Create" class="flex flex-col gap-3">
            <input type="text" name="login" placeholder="Login" required
                   class="input w-full bg-black text-white border-gray-700 rounded-lg" />
            <input type="email" name="email" placeholder="Email" required
                   class="input w-full bg-black text-white border-gray-700 rounded-lg" />
            <input type="password" name="password" placeholder="Password" required
                   class="input w-full bg-black text-white border-gray-700 rounded-lg" />
            <input type="text" name="firstName" placeholder="First Name" required
                   class="input w-full bg-black text-white border-gray-700 rounded-lg" />
            <input type="text" name="lastName" placeholder="Last Name" required
                   class="input w-full bg-black text-white border-gray-700 rounded-lg" />
            <input type="hidden" name="role" value="Worker" />
            <div class="modal-action">
                <button type="button" onclick="document.getElementById('modal-add-user').close()"
                        class="btn btn-ghost text-gray-400">Cancel</button>
                <button type="submit" class="btn bg-white text-black rounded-full hover:bg-gray-200">Add</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
