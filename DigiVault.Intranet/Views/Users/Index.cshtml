@{
    ViewData["Title"] = "Users";
    Layout = "_Layout";
}

@* FILTRY *@
<div class="flex gap-3 mb-6 flex-wrap">
    <label class="input input-sm rounded-full bg-black border-gray-700 flex items-center gap-2 w-64">
        <svg class="h-4 w-4 opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
            </g>
        </svg>
        <input type="search" placeholder="Search users..." class="bg-transparent text-white outline-none w-full text-sm" />
    </label>
    <select class="select select-sm bg-black text-white border-gray-700 rounded-full">
        <option>All Roles</option>
        <option>User</option>
        <option>Worker</option>
        <option>Admin</option>
    </select>
    <select class="select select-sm bg-black text-white border-gray-700 rounded-full">
        <option>All Status</option>
        <option>Active</option>
        <option>Banned</option>
    </select>
</div>

@* TABELA *@
<div class="card bg-black border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr class="text-gray-400 border-gray-800 bg-black">
                    <th>ID</th>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Warnings</th>
                    <th>Joined</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="text-gray-300">

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="text-gray-500 text-sm font-mono">1</td>
                    <td>
                        <div class="flex items-center gap-3">
                            <div class="avatar placeholder">
                            </div>
                            <div>
                                <p class="text-white text-sm font-semibold">Aleksandra Chełmińska</p>
                            </div>
                        </div>
                    </td>
                    <td class="text-sm">aleksandra@example.com</td>
                    <td><span class="badge badge-warning badge-sm rounded-lg">Worker</span></td>
                    <td><span class="badge badge-success badge-sm rounded-lg">Active</span></td>
                    <td class="text-center">0</td>
                    <td class="text-sm text-gray-500">01/01/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-eye"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                <i class="fa fa-ban"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="text-gray-500 text-sm font-mono">2</td>
                    <td>
                        <div class="flex items-center gap-3">
                            <div class="avatar placeholder">
                            </div>
                            <div>
                                <p class="text-white text-sm font-semibold">Jan Kowalski</p>
                            </div>
                        </div>
                    </td>
                    <td class="text-sm">jan@example.com</td>
                    <td><span class="badge bg-white text-black badge-sm rounded-lg">User</span></td>
                    <td><span class="badge badge-success badge-sm rounded-lg">Active</span></td>
                    <td class="text-center">1</td>
                    <td class="text-sm text-gray-500">15/02/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-eye"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                <i class="fa fa-ban"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="text-gray-500 text-sm font-mono">3</td>
                    <td>
                        <div class="flex items-center gap-3">
                            <div class="avatar placeholder">
                            </div>
                            <div>
                                <p class="text-white text-sm font-semibold">Anna Nowak</p>
                            </div>
                        </div>
                    </td>
                    <td class="text-sm">anna@example.com</td>
                    <td><span class="badge badge-warning badge-sm rounded-lg">Worker</span></td>
                    <td><span class="badge badge-error badge-sm rounded-lg">Banned</span></td>
                    <td class="text-center">3</td>
                    <td class="text-sm text-gray-500">10/03/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-eye"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-green-500 hover:text-green-400">
                                <i class="fa fa-check"></i>
                            </button>
                        </div>
                    </td>
                </tr>

            </tbody>
        </table>
    </div>
</div>