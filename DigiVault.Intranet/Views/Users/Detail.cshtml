@{
    ViewData["Title"] = "User Detail";
    Layout = "_Layout";
}

<div class="mb-4">
    <a href="/users" class="text-gray-400 hover:text-white text-sm">
        <i class="fa fa-arrow-left mr-2"></i>Back to Users
    </a>
</div>

<div class="flex flex-col lg:flex-row gap-8">

    @* LEWA STRONA *@
    <div class="flex-1">

        @* PROFIL *@
        <div class="card bg-black border border-gray-800 rounded-xl p-6 mb-6">
            <div class="flex items-center gap-4 mb-6">
                <div class="avatar placeholder">
                    <div class="bg-gray-700 text-white rounded-full w-16">
                        <span class="text-xl">AC</span>
                    </div>
                </div>
                <div>
                    <h1 class="text-white text-2xl font-bold">Aleksandra Chełmińska</h1>
                    <p class="text-gray-500 text-sm">aleksandra123</p>
                    <p class="text-gray-500 text-sm">aleksandra@example.com</p>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 text-sm">
                <div>
                    <p class="text-gray-400">Role</p>
                    <span class="badge badge-warning mt-1 rounded-full">Worker</span>
                </div>
                <div>
                    <p class="text-gray-400">Status</p>
                    <span class="badge badge-success mt-1 rounded-full">Active</span>
                </div>
                <div>
                    <p class="text-gray-400">Warnings</p>
                    <p class="text-white font-bold">0</p>
                </div>
                <div>
                    <p class="text-gray-400">Joined</p>
                    <p class="text-white">01/01/2026</p>
                </div>
                <div>
                    <p class="text-gray-400">Balance</p>
                    <p class="text-white font-bold">1,250.00 PLN</p>
                </div>
                <div>
                    <p class="text-gray-400">Total Withdrawn</p>
                    <p class="text-white font-bold">7,180.00 PLN</p>
                </div>
            </div>
        </div>

        @* KURSY UŻYTKOWNIKA *@
        <div class="card bg-black border border-gray-800 rounded-xl p-6 mb-6">
            <h2 class="text-white font-bold mb-4">Courses</h2>
            <div class="flex flex-col gap-2">
                <div class="flex gap-4 items-center py-3 border-b border-gray-800">
                    <img src="https://images.unsplash.com/photo-1526379095098-d400fd0bf935?w=400" 
                         class="w-16 h-10 object-cover rounded flex-shrink-0" />
                    <div class="flex-1">
                        <a href="/courses/detail/1" class="text-white text-sm font-semibold hover:text-gray-300 transition-colors">Python – Kompletny Kurs</a>
                        <p class="text-gray-500 text-xs">420 sales • 99.99 PLN</p>
                    </div>
                    <span class="badge badge-success badge-sm rounded-full text-black">Active</span>
                </div>
                <div class="flex gap-4 items-center py-3 border-b border-gray-800">
                    <img src="https://images.unsplash.com/photo-1544383835-bda2bc66a55d?w=400" 
                         class="w-16 h-10 object-cover rounded flex-shrink-0" />
                    <div class="flex-1">
                        <a href="/courses/detail/2" class="text-white text-sm font-semibold hover:text-gray-300 transition-colors">HTML i CSS od Zera</a>
                        <p class="text-gray-500 text-xs">450 sales • 49.99 PLN</p>
                    </div>
                    <span class="badge badge-success badge-sm rounded-full text-black">Active</span>
                </div>
            </div>
        </div>

        @* ZAMÓWIENIA UŻYTKOWNIKA *@
        <div class="card bg-black border border-gray-800 rounded-xl p-6">
            <h2 class="text-white font-bold mb-4">Orders</h2>
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-gray-400 border-gray-800">
                            <th>Order ID</th>
                            <th>Total</th>
                            <th>Items</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-300">
                        <tr class="border-gray-800">
                            <td class="font-mono text-xs">#1021</td>
                            <td>299.98 PLN</td>
                            <td>2 courses</td>
                            <td class="text-gray-500">25/03/2026</td>
                        </tr>
                        <tr class="border-gray-800">
                            <td class="font-mono text-xs">#1015</td>
                            <td>149.99 PLN</td>
                            <td>1 course</td>
                            <td class="text-gray-500">10/03/2026</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    @* PRAWA STRONA - admin actions *@
    <div class="lg:w-80">
        <div class="card bg-black border border-gray-800 rounded-xl p-6 sticky top-4">
            <h2 class="text-white font-bold mb-4">Admin Actions</h2>

            <div class="flex flex-col gap-3">
                <div class="flex flex-col gap-1">
                        <button class="btn btn-sm bg-yellow-400 text-black rounded-full hover:bg-yellow-500 flex-1">
                            Add Warning
                        </button>
                </div>

                <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800 my-1"></div>

                <button class="btn btn-error rounded-full w-full hover:bg-red-900 bg-red-700 border-0">
                    <i class="fa fa-ban mr-2"></i>Ban User
                </button>

                <button class="btn bg-black text-white border-gray-700 rounded-full w-full hover:bg-white hover:text-black">
                    <i class="fa fa-shield-alt mr-2"></i>Change Role
                </button>
            </div>
        </div>
    </div>

</div>