@model List<DigiVault.Intranet.Models.AdminCourseDto>
@{
    ViewData["Title"] = "Courses";
    Layout = "_Layout";
    var page = (int)(ViewData["Page"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var search = ViewData["Search"] as string;
}

@* FILTRY *@
<div class="flex gap-3 mb-6 flex-wrap justify-between">
    <form method="get" class="flex gap-3 flex-wrap">
        <label class="input input-sm rounded-full bg-black border-gray-700 flex items-center gap-2 w-64">
            <svg class="h-4 w-4 opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </g>
            </svg>
            <input type="search" name="search" value="@search" placeholder="Search courses..." class="bg-transparent text-white outline-none w-full text-sm" />
        </label>
        <select name="isActive" class="select select-sm bg-black text-white border-gray-700 rounded-full">
            <option value="">All Status</option>
            <option value="true">Active</option>
            <option value="false">Banned</option>
        </select>
        <button type="submit" class="btn btn-sm btn-ghost text-gray-400">Search</button>
    </form>
</div>

@* TABELA *@
<div class="card bg-black border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr class="text-gray-400 border-gray-800 bg-black">
                    <th>Course</th>
                    <th>Author</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Sales</th>
                    <th>Rating</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="text-gray-300">
                @foreach (var course in Model)
                {
                    <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                        <td>
                            <p class="text-white text-sm font-semibold">@course.Title</p>
                        </td>
                        <td class="text-sm">@course.AuthorName</td>
                        <td class="text-sm">@course.CategoryName</td>
                        <td class="text-sm">@course.Price.ToString("F2") PLN</td>
                        <td class="text-sm">@course.SalesCount</td>
                        <td class="text-sm">⭐ @course.AverageRating.ToString("F1")</td>
                        <td>
                            @if (!course.IsActive)
                            {
                                <span class="badge badge-error badge-sm rounded-xl">Banned</span>
                            }
                            else if (!course.IsVisible)
                            {
                                <span class="badge badge-warning badge-sm rounded-xl">Hidden</span>
                            }
                            else
                            {
                                <span class="badge badge-success badge-sm rounded-xl">Active</span>
                            }
                        </td>
                        <td>
                            <div class="flex gap-2">
                                <a href="/courses/detail/@course.IdCourse"
                                   class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                    <i class="fa fa-eye"></i>
                                </a>
                                @if (course.IsActive)
                                {
                                    <form method="post" asp-action="Delete" asp-route-id="@course.IdCourse"
                                          onsubmit="return confirm('Ban this course?')">
                                        <button type="submit" class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                            <i class="fa fa-ban"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* PAGINACJA *@
@if (totalPages > 1)
{
    <div class="flex justify-center gap-2 mt-6">
        @for (int i = 1; i <= totalPages; i++)
        {
            <a href="?page=@i&search=@search"
               class="btn btn-sm @(i == page ? "bg-white text-black" : "btn-ghost text-gray-400") rounded-full">
                @i
            </a>
        }
    </div>
}
