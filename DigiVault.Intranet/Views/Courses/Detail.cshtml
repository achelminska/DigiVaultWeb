@model DigiVault.Intranet.Models.AdminCourseDetailDto
@{
    ViewData["Title"] = "Course Detail";
    Layout = "_Layout";
}

<div class="mb-4">
    <a href="/courses" class="text-gray-400 hover:text-white text-sm">
        <i class="fa fa-arrow-left mr-2"></i>Back to Courses
    </a>
</div>

<div class="flex flex-col lg:flex-row gap-8">

    @* LEWA STRONA *@
    <div class="flex-1">

        <span class="badge badge-outline text-white border-gray-600 rounded-full px-4 py-3 mb-4">@Model.CategoryName</span>
        <h1 class="text-white text-3xl font-bold mt-4 mb-3">@Model.Title</h1>
        <p class="text-gray-400 mb-4">@Model.Description</p>

        <div class="flex items-center gap-2 text-gray-400 text-sm mb-2">
            <i class="fa fa-user"></i>
            <span class="hover:text-white transition-colors">@Model.AuthorName</span>
        </div>

        <div class="flex items-center gap-2 text-yellow-400 mb-2">
            ⭐⭐⭐⭐⭐
            <span class="text-white font-bold">@Model.AverageRating.ToString("F1")</span>
        </div>

        <div class="flex gap-6 text-gray-400 text-sm mb-6">
            <span>🛒 @Model.SalesCount sold</span>
            <span>📅 @Model.CreatedAt.ToString("dd/MM/yyyy")</span>
        </div>

        <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800"></div>

        <div class="mb-6">
            <h2 class="text-white text-xl font-bold mb-3">About</h2>
            <p class="text-gray-400">@Model.Description</p>
        </div>

        <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800"></div>

        @* ZGŁOSZENIA *@
        <div class="mb-6">
            <h2 class="text-white text-xl font-bold mb-4">
                Reports
                <span class="badge bg-yellow-400 text-black badge-sm ml-2 rounded-xl">@Model.ReportsCount pending</span>
            </h2>
            <a href="/reports" class="text-gray-400 text-sm hover:text-white">View all reports →</a>
        </div>

    </div>

    @* PRAWA STRONA - admin panel *@
    <div class="lg:w-96">
        <div class="card bg-black border border-gray-800 rounded-xl overflow-hidden sticky top-4">

            @* OBRAZEK *@
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="aspect-video overflow-hidden">
                    <img src="@Model.ImageUrl" class="w-full h-full object-cover" />
                </div>
            }

            <div class="p-6">
                <p class="text-white text-3xl font-bold mb-4">@Model.Price.ToString("F2") PLN</p>

                <div class="flex flex-col gap-2 text-gray-400 text-sm mb-6">
                    <div class="flex justify-between">
                        <span>Status</span>
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success badge-sm rounded-xl">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-error badge-sm rounded-xl">Banned</span>
                        }
                    </div>
                    <div class="flex justify-between">
                        <span>Visibility</span>
                        @if (Model.IsVisible)
                        {
                            <span class="badge badge-success badge-sm rounded-xl">Visible</span>
                        }
                        else
                        {
                            <span class="badge badge-warning badge-sm rounded-xl">Hidden</span>
                        }
                    </div>
                    <div class="flex justify-between">
                        <span>Category</span>
                        <span class="text-white">@Model.CategoryName</span>
                    </div>
                    <div class="flex justify-between">
                        <span>Rating</span>
                        <span class="text-white">@Model.AverageRating.ToString("F1") ⭐</span>
                    </div>
                    <div class="flex justify-between">
                        <span>Sales</span>
                        <span class="text-white">@Model.SalesCount</span>
                    </div>
                </div>

                <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800 my-2"></div>

                <div class="flex flex-col gap-2">
                    @if (Model.IsActive)
                    {
                        <button onclick="document.getElementById('modal-ban-course').showModal()"
                                class="btn bg-red-800 rounded-full w-full hover:bg-red-900">
                            <i class="fa fa-ban mr-2"></i>Ban Course
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

</div>

@* MODAL: BAN COURSE *@
<dialog id="modal-ban-course" class="modal">
    <div class="modal-box bg-black border border-gray-800">
        <h3 class="text-white font-bold text-lg mb-2">Ban Course</h3>
        <p class="text-gray-400 mb-4">Are you sure you want to ban <span class="text-white font-semibold">@Model.Title</span>? Users who purchased it will keep access.</p>
        <form method="post" asp-controller="Courses" asp-action="Delete" asp-route-id="@Model.IdCourse">
            <div class="modal-action">
                <button type="button" onclick="document.getElementById('modal-ban-course').close()"
                        class="btn btn-ghost text-gray-400">Cancel</button>
                <button type="submit" class="btn btn-error rounded-full">Ban</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
