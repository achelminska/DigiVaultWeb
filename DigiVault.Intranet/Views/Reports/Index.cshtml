@model List<DigiVault.Intranet.Models.AdminReportDto>
@{
    ViewData["Title"] = "Reports";
    Layout = "_Layout";
    var page = (int)(ViewData["Page"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var isResolved = ViewData["IsResolved"] as bool?;
}

@* FILTRY *@
<div class="flex gap-3 mb-6 flex-wrap">
    <a href="?isResolved=&page=1"
       class="btn btn-sm @(isResolved == null ? "bg-white text-black" : "btn-ghost text-gray-400") rounded-full">
        All
    </a>
    <a href="?isResolved=false&page=1"
       class="btn btn-sm @(isResolved == false ? "bg-white text-black" : "btn-ghost text-gray-400") rounded-full">
        Pending
    </a>
    <a href="?isResolved=true&page=1"
       class="btn btn-sm @(isResolved == true ? "bg-white text-black" : "btn-ghost text-gray-400") rounded-full">
        Resolved
    </a>
</div>

@* TABELA *@
<div class="card bg-black border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr class="text-gray-400 border-gray-800 bg-black">
                    <th>Course</th>
                    <th>Reported By</th>
                    <th>Reason</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="text-gray-300">
                @foreach (var report in Model)
                {
                    <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                        <td>
                            <p class="text-white text-sm font-semibold">@report.CourseTitle</p>
                        </td>
                        <td>
                            <p class="text-white text-sm">@report.ReportedBy</p>
                        </td>
                        <td class="text-sm max-w-xs truncate">@report.Reason</td>
                        <td class="text-sm text-gray-500">@report.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (report.IsResolved)
                            {
                                <span class="badge badge-success badge-sm bg-green-900 text-black rounded-xl">Resolved</span>
                            }
                            else
                            {
                                <span class="badge badge-warning badge-sm rounded-xl bg-yellow-400 text-black">Pending</span>
                            }
                        </td>
                        <td>
                            <div class="flex gap-2">
                                <a href="/courses/detail/@report.IdCourse" class="btn btn-ghost btn-xs text-blue-400 hover:text-blue-300">
                                    <i class="fa fa-book"></i>
                                </a>
                                <button onclick="openDetailModal('@report.CourseTitle', '@report.ReportedBy', '@report.Reason', '@report.CreatedAt.ToString("dd/MM/yyyy")')"
                                        class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                    <i class="fa fa-eye"></i>
                                </button>
                                @if (!report.IsResolved)
                                {
                                    <form method="post" asp-action="Resolve" asp-route-id="@report.IdCourseReport"
                                          onsubmit="return confirm('Mark as resolved?')">
                                        <button type="submit" class="btn btn-ghost btn-xs text-green-500 hover:text-green-400">
                                            <i class="fa fa-check"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* MODAL: DETAIL *@
<dialog id="modal-report-detail" class="modal">
    <div class="modal-box bg-black border border-gray-800">
        <h3 class="text-white font-bold text-lg mb-4">Report Details</h3>
        <div class="flex flex-col gap-3 text-sm">
            <div>
                <p class="text-gray-400 mb-1">Course</p>
                <p id="detail-course" class="text-white font-semibold"></p>
            </div>
            <div>
                <p class="text-gray-400 mb-1">Reported By</p>
                <p id="detail-user" class="text-white"></p>
            </div>
            <div>
                <p class="text-gray-400 mb-1">Date</p>
                <p id="detail-date" class="text-white"></p>
            </div>
            <div>
                <p class="text-gray-400 mb-1">Reason</p>
                <p id="detail-reason" class="text-gray-300 leading-relaxed"></p>
            </div>
        </div>
        <div class="modal-action">
            <button onclick="document.getElementById('modal-report-detail').close()"
                    class="btn bg-white text-black rounded-full hover:bg-gray-200">Close</button>
        </div>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

<script>
    function openDetailModal(course, user, reason, date) {
        document.getElementById('detail-course').textContent = course;
        document.getElementById('detail-user').textContent = user;
        document.getElementById('detail-reason').textContent = reason;
        document.getElementById('detail-date').textContent = date;
        document.getElementById('modal-report-detail').showModal();
    }
</script>

@* PAGINACJA *@
@if (totalPages > 1)
{
    <div class="flex justify-center gap-2 mt-6">
        @for (int i = 1; i <= totalPages; i++)
        {
            <a href="?page=@i@(isResolved.HasValue ? $"&isResolved={isResolved}" : "")"
               class="btn btn-sm @(i == page ? "bg-white text-black" : "btn-ghost text-gray-400") rounded-full">
                @i
            </a>
        }
    </div>
}
