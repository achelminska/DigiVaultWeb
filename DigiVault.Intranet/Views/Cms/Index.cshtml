@{
    ViewData["Title"] = "CMS";
    Layout = "_Layout";
}

@* PRZYCISKI GÓRNE *@
<div class="flex justify-end mb-6">
    <button class="btn bg-white text-black rounded-full btn-sm px-6 hover:bg-gray-200">
        + Add Content
    </button>
</div>

@* TABELA *@
<div class="card bg-black border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr class="text-gray-400 border-gray-800 bg-black">
                    <th>Key</th>
                    <th>Value</th>
                    <th>Last Updated</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="text-gray-300">

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="font-mono text-xs text-gray-400">home.hero.title</td>
                    <td class="text-white text-sm">Odkryj kursy które zmienią Twoją karierę</td>
                    <td class="text-sm text-gray-500">25/03/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-edit"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="font-mono text-xs text-gray-400">home.hero.subtitle</td>
                    <td class="text-white text-sm">Ponad 1000 kursów od najlepszych ekspertów</td>
                    <td class="text-sm text-gray-500">25/03/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-edit"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="font-mono text-xs text-gray-400">footer.copyright</td>
                    <td class="text-white text-sm">© 2026 DigiVault. All rights reserved.</td>
                    <td class="text-sm text-gray-500">20/03/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-edit"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="font-mono text-xs text-gray-400">about.description</td>
                    <td class="text-white text-sm">DigiVault to platforma e-learningowa łącząca studentów z ekspertami.</td>
                    <td class="text-sm text-gray-500">18/03/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-edit"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                    <td class="font-mono text-xs text-gray-400">terms.content</td>
                    <td class="text-white text-sm truncate max-w-xs">Regulamin korzystania z platformy DigiVault...</td>
                    <td class="text-sm text-gray-500">15/03/2026</td>
                    <td>
                        <div class="flex gap-2">
                            <button class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-edit"></i>
                            </button>
                            <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">
                                <i class="fa fa-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>

            </tbody>
        </table>
    </div>
</div>