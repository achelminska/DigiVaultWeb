@model List<DigiVault.Intranet.Models.AdminCmsContentDto>
@{
    ViewData["Title"] = "CMS";
    Layout = "_Layout";
    var page = (int)ViewData["Page"]!;
    var totalPages = (int)ViewData["TotalPages"]!;
    var search = ViewData["Search"] as string;
}

<div class="flex gap-3 mb-6 flex-wrap justify-between">
    <form method="get" class="flex gap-3">
        <label class="input input-sm rounded-full bg-black border-gray-700 flex items-center gap-2 w-64">
            <svg class="h-4 w-4 opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                    <circle cx="11" cy="11" r="8"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </g>
            </svg>
            <input type="search" name="search" value="@search" placeholder="Search key, title, value..." class="bg-transparent text-white outline-none w-full text-sm" />
        </label>
        <button type="submit" class="btn btn-sm btn-ghost text-gray-400">Search</button>
    </form>
    <button onclick="document.getElementById('modal-add').showModal()" class="btn bg-white text-black rounded-full btn-sm px-6 hover:bg-gray-200">
        + Add Content
    </button>
</div>

<div class="card bg-black border border-gray-800 rounded-xl overflow-hidden">
    <div class="overflow-x-auto">
        <table class="table">
            <thead>
                <tr class="text-gray-400 border-gray-800 bg-black">
                    <th>Key</th>
                    <th>Title</th>
                    <th>Value</th>
                    <th>Last Updated</th>
                    <th></th>
                </tr>
            </thead>
            <tbody class="text-gray-300">
                @foreach (var item in Model)
                {
                    <tr class="border-gray-800 hover:bg-gray-900 transition-colors">
                        <td class="font-mono text-xs text-gray-400">@item.Key</td>
                        <td class="text-white text-sm">@item.Title</td>
                        <td class="text-white text-sm truncate max-w-xs">@item.Value</td>
                        <td class="text-sm text-gray-500">@item.LastUpdated.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.IdContent"
                               class="btn btn-ghost btn-xs text-gray-400 hover:text-white">
                                <i class="fa fa-edit"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <div class="flex justify-center gap-2 mt-6">
        @for (int i = 1; i <= totalPages; i++)
        {
            <a href="?page=@i&search=@search"
               class="btn btn-sm @(i == page ? "bg-white text-black" : "btn-ghost text-gray-400") rounded-full">
                @i
            </a>
        }
    </div>
}

<dialog id="modal-add" class="modal">
    <div class="modal-box bg-black border border-gray-800 max-w-lg">
        <h3 class="text-white font-bold text-lg mb-4">Add CMS Content</h3>
        <form method="post" asp-action="Create">
            <label class="text-gray-400 text-xs">Key</label>
            <input type="text" name="key" placeholder="e.g. home.hero.title" required
                   class="input w-full bg-black text-white border-gray-700 rounded-lg mb-3 font-mono text-sm" />
            <label class="text-gray-400 text-xs">Title (admin label)</label>
            <input type="text" name="title" placeholder="Display title" required
                   class="input w-full bg-black text-white border-gray-700 rounded-lg mb-3" />
            <label class="text-gray-400 text-xs">Value</label>
            <textarea name="value" rows="4" placeholder="Content shown on portal" required
                      class="textarea w-full bg-black text-white border-gray-700 rounded-lg mb-4"></textarea>
            <div class="modal-action">
                <button type="button" onclick="document.getElementById('modal-add').close()"
                        class="btn btn-ghost text-gray-400">Cancel</button>
                <button type="submit" class="btn bg-white text-black rounded-full hover:bg-gray-200">Add</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
