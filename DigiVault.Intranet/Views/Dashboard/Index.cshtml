@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

@* STATYSTYKI *@
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">

    <div class="card bg-black border border-gray-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-2">
            <p class="text-gray-400 text-sm">Total Users</p>
            <i class="fa fa-users text-gray-600"></i>
        </div>
        <p class="text-white text-3xl font-bold">1,284</p>
        <p class="text-green-500 text-xs mt-1">+12 this week</p>
    </div>

    <div class="card bg-black border border-gray-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-2">
            <p class="text-gray-400 text-sm">Total Courses</p>
            <i class="fa fa-book text-gray-600"></i>
        </div>
        <p class="text-white text-3xl font-bold">48</p>
        <p class="text-green-500 text-xs mt-1">+3 this week</p>
    </div>

    <div class="card bg-black border border-gray-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-2">
            <p class="text-gray-400 text-sm">Total Orders</p>
            <i class="fa fa-shopping-cart text-gray-600"></i>
        </div>
        <p class="text-white text-3xl font-bold">3,921</p>
        <p class="text-green-500 text-xs mt-1">+84 this week</p>
    </div>

    <div class="card bg-black border border-gray-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-2">
            <p class="text-gray-400 text-sm">Platform Revenue</p>
            <i class="fa fa-dollar-sign text-gray-600"></i>
        </div>
        <p class="text-white text-3xl font-bold">24,830 PLN</p>
        <p class="text-green-500 text-xs mt-1">+1,240 this week</p>
    </div>

</div>

@* OSTATNIE ZAMÓWIENIA *@
<div class="card bg-black border border-gray-800 rounded-xl p-6 mb-6">
    <h2 class="text-white font-bold mb-4">Recent Orders</h2>
    <div class="overflow-x-auto">
        <table class="table table-sm">
            <thead>
                <tr class="text-gray-400 border-gray-800">
                    <th>ID</th>
                    <th>User</th>
                    <th>Total</th>
                    <th>Date</th>
                    <th>Items</th>
                </tr>
            </thead>
            <tbody class="text-gray-300">
                <tr class="border-gray-800">
                    <td class="font-mono text-xs">#1021</td>
                    <td>Aleksandra Chełmińska</td>
                    <td>299.98 PLN</td>
                    <td>25/03/2026</td>
                    <td>2</td>
                </tr>
                <tr class="border-gray-800">
                    <td class="font-mono text-xs">#1020</td>
                    <td>Jan Kowalski</td>
                    <td>149.99 PLN</td>
                    <td>24/03/2026</td>
                    <td>1</td>
                </tr>
                <tr class="border-gray-800">
                    <td class="font-mono text-xs">#1019</td>
                    <td>Anna Nowak</td>
                    <td>479.97 PLN</td>
                    <td>24/03/2026</td>
                    <td>3</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@* OSTATNIE ZGŁOSZENIA *@
<div class="card bg-black border border-gray-800 rounded-xl p-6">
    <h2 class="text-white font-bold mb-4">Pending Reports</h2>
    <div class="flex flex-col gap-3">
        <div class="flex items-center justify-between py-2 border-b border-gray-800">
            <div>
                <p class="text-white text-sm">Python – Kompletny Kurs</p>
                <p class="text-gray-500 text-xs">Reported by Jan Kowalski • 24/03/2026</p>
            </div>
            <span class="badge badge-warning badge-sm rounded-lg">Pending</span>
        </div>
        <div class="flex items-center justify-between py-2 border-b border-gray-800">
            <div>
                <p class="text-white text-sm">HTML i CSS od Zera</p>
                <p class="text-gray-500 text-xs">Reported by Anna Nowak • 23/03/2026</p>
            </div>
            <span class="badge badge-warning badge-sm rounded-lg">Pending</span>
        </div>
    </div>
</div>