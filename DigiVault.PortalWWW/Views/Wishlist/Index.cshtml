@{
    ViewData["Title"] = "Wishlist";
    Layout = "_Layout";
}

@* NAGŁÓWEK *@
<section class="py-6">
    <h1 class="text-white text-4xl font-bold">Wishlist</h1>
    <p class="text-gray-400 text-sm mt-2">3 courses</p>
</section>

@* LISTA *@
<section class="mb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">

        <div class="card bg-black hover:scale-105 transition-transform cursor-pointer border border-gray-800 rounded-lg">
            <figure class="relative">
                <img src="https://images.unsplash.com/photo-1526379095098-d400fd0bf935?w=400" 
                     class="w-full h-40 object-cover" />
                <button class="absolute top-2 right-2 btn btn-circle btn-sm bg-black bg-opacity-50 border-none text-red-500 hover:text-red-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                    </svg>
                </button>
            </figure>
            <div class="card-body p-4">
                <h3 class="card-title text-white text-sm">Vue.js 3 – Kompletny Przewodnik</h3>
                <p class="text-gray-400 text-xs">Aleksandra Chełmińska</p>
                <div class="flex items-center gap-1 text-yellow-400 text-xs">⭐ 4.5 <span class="text-gray-400">(95)</span></div>
                <p class="text-white font-bold">159.99 PLN</p>
                <button class="btn btn-primary btn-sm rounded-full mt-2 bg-black hover:bg-white hover:text-black">Add to Cart</button>
            </div>
        </div>

        <div class="card bg-black hover:scale-105 transition-transform cursor-pointer border border-gray-800 rounded-lg">
            <figure class="relative">
                <img src="https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?w=400" 
                     class="w-full h-40 object-cover" />
                <button class="absolute top-2 right-2 btn btn-circle btn-sm bg-black bg-opacity-50 border-none text-red-500 hover:text-red-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                    </svg>
                </button>
            </figure>
            <div class="card-body p-4">
                <h3 class="card-title text-white text-sm">Bezpieczeństwo Sieci Komputerowych</h3>
                <p class="text-gray-400 text-xs">Aleksandra Chełmińska</p>
                <div class="flex items-center gap-1 text-yellow-400 text-xs">⭐ 4.4 <span class="text-gray-400">(67)</span></div>
                <p class="text-white font-bold">179.99 PLN</p>
                <button class="btn btn-primary btn-sm rounded-full w-full mt-2 bg-black hover:bg-white hover:text-black">Add to Cart</button>
            </div>
        </div>

        <div class="card bg-black hover:scale-105 transition-transform cursor-pointer">
            <figure class="relative">
                <img src="https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=400" 
                     class="w-full h-40 object-cover" />
                <button class="absolute top-2 right-2 btn btn-circle btn-sm bg-black bg-opacity-50 border-none text-red-500 hover:text-red-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                    </svg>
                </button>
            </figure>
            <div class="card-body p-4">
                <h3 class="card-title text-white text-sm">C# – Programowanie Obiektowe</h3>
                <p class="text-gray-400 text-xs">Aleksandra Chełmińska</p>
                <div class="flex items-center gap-1 text-yellow-400 text-xs">⭐ 4.7 <span class="text-gray-400">(195)</span></div>
                <p class="text-white font-bold">139.99 PLN</p>
                <button class="btn btn-primary btn-sm rounded-full w-full mt-2 bg-black hover:bg-white hover:text-black">Add to Cart</button>
            </div>
        </div>

    </div>
</section>