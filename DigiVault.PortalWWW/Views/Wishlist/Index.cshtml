@model List<DigiVault.PortalWWW.Models.CourseListDto>
@{
    ViewData["Title"] = "Wishlist";
    Layout = "_Layout";
}

<section class="py-6">
    <h1 class="text-white text-4xl font-bold">Wishlist</h1>
    <p class="text-gray-400 text-sm mt-2">@Model.Count course@(Model.Count != 1 ? "s" : "")</p>
</section>

<section class="mb-20">
    @if (!Model.Any())
    {
        <div class="text-center py-20">
            <p class="text-gray-400 text-lg">Your wishlist is empty.</p>
            <a href="/Courses" class="btn bg-white text-black rounded-full mt-4">Browse Courses</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            @foreach (var course in Model)
            {
                <div class="card bg-black hover:scale-105 transition-transform border border-gray-800 rounded-lg">
                    <figure class="relative">
                        <a href="/Courses/Detail/@course.IdCourse">
                            <img src="@(course.ImageUrl ?? "https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=400")"
                                 class="w-full h-40 object-cover" />
                        </a>
                        <form method="post" action="/Wishlist/Remove" class="absolute top-2 right-2">
                            <input type="hidden" name="idCourse" value="@course.IdCourse" />
                            <button type="submit" class="btn btn-circle btn-sm bg-black bg-opacity-50 border-none text-red-500 hover:text-red-400">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                                </svg>
                            </button>
                        </form>
                    </figure>
                    <div class="card-body p-4">
                        <a href="/Courses/Detail/@course.IdCourse">
                            <h3 class="card-title text-white text-sm hover:underline">@course.Title</h3>
                        </a>
                        <p class="text-gray-400 text-xs">@course.AuthorName</p>
                        @await Html.PartialAsync("_RatingStars", (course.AverageRating, course.RatingsCount))
                        <div class="flex justify-between items-center mt-2">
                            <p class="text-white font-bold">@course.Price.ToString("F2") PLN</p>
                            <form method="post" action="/Cart/Add">
                                <input type="hidden" name="idCourse" value="@course.IdCourse" />
                                <input type="hidden" name="returnUrl" value="/Wishlist" />
                                <button type="submit" class="btn btn-circle bg-base-content text-black border border-gray-300 hover:bg-black hover:text-gray-300 hover:border-gray-300 transition-colors flex items-center justify-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="9" cy="21" r="1"></circle>
                                        <circle cx="20" cy="21" r="1"></circle>
                                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>
