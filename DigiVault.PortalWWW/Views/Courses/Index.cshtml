@model CoursesIndexViewModel

@{
    ViewData["Title"] = "Find Course";
    Layout = "_Layout";
}

@* TYTUŁ *@
<section class="py-6">
    <h1 class="text-white text-4xl font-bold">Search</h1>
</section>

@* WYSZUKIWARKA *@
<section class="mb-4">
    <form asp-action="Index" method="get">
        <input type="hidden" name="sortBy" value="@Model.CurrentSortBy" />
        <input type="hidden" name="idCategory" value="@Model.CurrentCategory" />
    <label class="input rounded-full bg-black border-gray-700 w-full flex items-center gap-2">
        <svg class="h-[1em] opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
            </g>
        </svg>
        <input type="search" placeholder="Search courses..." value="@Model.CurrentSearch" name="search" class="bg-transparent text-white outline-none w-full" />
    </label>
    </form>
</section>

@* FILTRY *@
<section class="mb-6">
    @* SORTOWANIE *@
    <div class="flex flex-wrap gap-3 mb-3">
        @{ var sortOptions = new[] { ("popular", "Popular"), ("newest", "Newest"), ("top-rated", "Top Rated") }; }
        @foreach (var (value, label) in sortOptions)
        {
            var sortClass = Model.CurrentSortBy == value ? "bg-white text-black border-white" : "text-white border-gray-500 hover:bg-white hover:text-black";
            <a asp-action="Index"
               asp-route-sortBy="@value"
               asp-route-search="@Model.CurrentSearch"
               asp-route-idCategory="@Model.CurrentCategory"
               class="badge badge-outline rounded-full px-4 py-3 cursor-pointer hover:scale-105 transition-transform @sortClass">
                @label
            </a>
        }
    </div>

    @* KATEGORIE *@
    <div class="flex flex-wrap gap-3">
        
        @foreach (var category in Model.Categories)
        {
            var categoryClass = Model.CurrentCategory == category.IdCategory ? "bg-white text-black border-white" : "text-white border-gray-500 hover:bg-white hover:text-black";
            <a asp-action="Index" 
               asp-route-idCategory="@category.IdCategory"
               asp-route-search="@Model.CurrentSearch"
               asp-route-sortBy="@Model.CurrentSortBy"
               class="badge badge-outline rounded-full px-4 py-3 cursor-pointer hover:scale-105 transition-transform @categoryClass">
                @category.Name
            </a>
        }
    </div>
</section>

@* RESULTS *@
<section class="mb-20">
    <div class="flex justify-between items-center mb-4">
        <h2 class="text-white text-2xl font-bold">Results</h2>
        <span class="text-gray-400 text-sm">@Model.Courses.Count() courses</span>
    </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    @foreach (var course in Model.Courses)
    {
        <a asp-controller="Courses" asp-action="Detail" asp-route-id="@course.IdCourse">
            <div class="card bg-black hover:scale-105 transition-transform cursor-pointer border border-gray-800 rounded-lg" style="height: 320px;">
                <figure class="flex-shrink-0">
                    <img src="@(course.ImageUrl ?? "/images/default.png")" class="w-full h-40 object-cover" />
                </figure>
                <div class="card-body p-4 flex flex-col">
                    <h3 class="card-title text-white text-sm line-clamp-2">@course.Title</h3>
                    <p class="text-gray-400 text-xs">@course.AuthorName</p>
                    @await Html.PartialAsync("_RatingStars", (course.AverageRating, course.RatingsCount))
                    <p class="text-white font-bold mt-auto">@course.Price.ToString("0.00") PLN</p>
                </div>
            </div>
        </a>
    }
</div>

</section>

@* PAGINATION *@
@if (Model.TotalPages > 1)
{
    <div class="flex justify-center gap-2 mt-6">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            var pageClass = i == Model.CurrentPage ? "bg-white text-black" : "bg-black text-white border-gray-700";
            <a asp-action="Index" asp-route-page="@i"
                asp-route-search="@Model.CurrentSearch"
                asp-route-idCategory="@Model.CurrentCategory"
                asp-route-sortBy="@Model.CurrentSortBy"
                class="btn btn-sm rounded-full @pageClass">
                @i
            </a>
        }
    </div>
}