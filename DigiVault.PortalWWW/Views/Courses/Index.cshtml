@model CoursesIndexViewModel

@{
    ViewData["Title"] = "Explore Courses";
    Layout = "_Layout";
}

@* ── HEADER + SEARCH ────────────────────────────────────── *@
<section class="animate-fade-up py-4">
    <h1 class="font-display text-3xl font-extrabold text-white sm:text-4xl">Explore Courses</h1>
    <p class="mt-2 text-zinc-500">Find your next skill among @Model.Courses.Count() results</p>

    <form asp-action="Index" method="get" class="mt-6">
        <input type="hidden" name="sortBy" value="@Model.CurrentSortBy" />
        <input type="hidden" name="idCategory" value="@Model.CurrentCategory" />
        <label class="flex w-full max-w-2xl items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.04] px-5 py-3.5 transition-colors focus-within:border-brand-400/60 focus-within:bg-white/[0.07]">
            <svg class="h-5 w-5 shrink-0 text-zinc-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
            <input type="search" placeholder="Search courses…" value="@Model.CurrentSearch" name="search"
                   class="w-full bg-transparent text-white placeholder-zinc-500 outline-none" />
            <button type="submit" class="btn btn-gradient btn-sm rounded-full px-5 font-semibold">Search</button>
        </label>
    </form>
</section>

@* ── FILTERS ────────────────────────────────────────────── *@
<section class="animate-fade-up dv-delay-1 mb-8 flex flex-col gap-3">
    <div class="flex flex-wrap items-center gap-2">
        <span class="mr-1 text-xs font-semibold uppercase tracking-widest text-zinc-600">Sort</span>
        @{ var sortOptions = new[] { ("popular", "Popular"), ("newest", "Newest"), ("top-rated", "Top Rated") }; }
        @foreach (var (value, label) in sortOptions)
        {
            var active = Model.CurrentSortBy == value;
            <a asp-action="Index"
               asp-route-sortBy="@value"
               asp-route-search="@Model.CurrentSearch"
               asp-route-idCategory="@Model.CurrentCategory"
               class="rounded-full px-4 py-1.5 text-sm font-medium transition-all @(active
                   ? "bg-gradient-to-r from-violet-600 to-fuchsia-600 text-white shadow-lg shadow-violet-600/25"
                   : "border border-white/10 text-zinc-400 hover:border-brand-400/60 hover:text-white")">
                @label
            </a>
        }
    </div>

    <div class="flex flex-wrap items-center gap-2">
        <span class="mr-1 text-xs font-semibold uppercase tracking-widest text-zinc-600">Category</span>
        @foreach (var category in Model.Categories)
        {
            var active = Model.CurrentCategory == category.IdCategory;
            <a asp-action="Index"
               asp-route-idCategory="@category.IdCategory"
               asp-route-search="@Model.CurrentSearch"
               asp-route-sortBy="@Model.CurrentSortBy"
               class="rounded-full px-4 py-1.5 text-sm font-medium transition-all @(active
                   ? "bg-gradient-to-r from-violet-600 to-fuchsia-600 text-white shadow-lg shadow-violet-600/25"
                   : "border border-white/10 text-zinc-400 hover:border-brand-400/60 hover:text-white")">
                @category.Name
            </a>
        }
    </div>
</section>

@* ── RESULTS ────────────────────────────────────────────── *@
<section class="animate-fade-up dv-delay-2 mb-16">
    @if (!Model.Courses.Any())
    {
        <div class="flex flex-col items-center rounded-3xl border border-white/[0.08] bg-ink-900 py-20 text-center">
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-white/5 text-zinc-500">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                </svg>
            </div>
            <p class="text-lg font-semibold text-white">No courses found</p>
            <p class="mt-1 text-sm text-zinc-500">Try a different search or clear the filters.</p>
            <a href="/courses" class="btn mt-6 rounded-full border border-white/15 bg-transparent px-8 text-white hover:border-white/40 hover:bg-white/5">Clear filters</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            @foreach (var course in Model.Courses)
            {
                @await Html.PartialAsync("_CourseCard", course)
            }
        </div>
    }
</section>

@* ── PAGINATION ─────────────────────────────────────────── *@
@if (Model.TotalPages > 1)
{
    <div class="mb-10 flex justify-center gap-2">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            var active = i == Model.CurrentPage;
            <a asp-action="Index" asp-route-page="@i"
               asp-route-search="@Model.CurrentSearch"
               asp-route-idCategory="@Model.CurrentCategory"
               asp-route-sortBy="@Model.CurrentSortBy"
               class="flex h-10 w-10 items-center justify-center rounded-full text-sm font-semibold transition-all @(active
                   ? "bg-gradient-to-r from-violet-600 to-fuchsia-600 text-white shadow-lg shadow-violet-600/25"
                   : "border border-white/10 text-zinc-400 hover:border-brand-400/60 hover:text-white")">
                @i
            </a>
        }
    </div>
}
