@{
    ViewData["Title"] = "Find Course";
    Layout = "_Layout";
}

@* TYTUŁ *@
<section class="py-6">
    <h1 class="text-white text-4xl font-bold">Search</h1>
</section>

@* WYSZUKIWARKA *@
<section class="mb-4">
    <label class="input rounded-full bg-black border-gray-700 w-full flex items-center gap-2">
        <svg class="h-[1em] opacity-50" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.3-4.3"></path>
            </g>
        </svg>
        <input type="search" placeholder="Search courses..." class="bg-transparent text-white outline-none w-full" />
    </label>
</section>

@* FILTRY *@
<section class="mb-6">
    <div class="flex flex-wrap gap-3">
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Popular</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Newest</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Top Rated</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">ReactJS</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Web Development</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Mobile Development</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">DevOps & Cloud</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Databases</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Cybersecurity</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Data Science & AI</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">UI/UX Design</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Programming Languages</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Software Architecture</span>
        <span class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">Productivity & Tools</span>
    </div>
</section>

