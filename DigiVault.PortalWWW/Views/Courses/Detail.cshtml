@model CourseDetailViewModel

@{
    ViewData["Title"] = "Course Detail";
    Layout = "_Layout";
    var course = Model.Course;
}

<section class="py-6">
    <div class="flex flex-col lg:flex-row gap-8">

        @* LEWA STRONA - info *@
        <div class="flex-1">

            <span class="badge badge-outline text-white border-gray-600 rounded-full px-4 py-3 mb-4">@course.CategoryName</span>
            <h1 class="text-white text-3xl font-bold mt-4 mb-3">@course.Title</h1>
            <p class="text-gray-400 mb-4">@course.Description</p>

            <div class="flex items-center gap-2 text-gray-400 text-sm mb-2">
                <i class="fa fa-user"></i>
                <span>@course.AuthorName</span>
            </div>

            <div class="flex items-center gap-2 text-yellow-400 mb-2">
                ⭐⭐⭐⭐⭐
                <span class="text-white font-bold">@course.AverageRating.ToString("0.0")</span>
                <span class="text-gray-400 text-sm">(@course.RatingsCount reviews)</span>
            </div>

            <div class="flex gap-6 text-gray-400 text-sm mb-6">
                <span>🛒 @course.SalesCount sold</span>
                <span>@course.CreatedAt.ToString("dd/MM/yyyy")</span>
            </div>

            <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800"></div>

            <div class="mb-6">
                <h2 class="text-white text-xl font-bold mb-3">About</h2>
                <p class="text-gray-400">@course.Description</p>
            </div>

            <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800"></div>

            <div class="mb-20">
                <h2 class="text-white text-xl font-bold mb-4">Reviews</h2>
                <div class="flex flex-col gap-4">
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="bg-black border border-gray-800 rounded-xl p-4">
                            <div class="flex items-center gap-3 mb-2">
                                <div class="avatar placeholder">
                                    <div class="bg-gray-700 text-white rounded-full w-9">
                                        <span class="text-sm">@(review.AuthorName.Length >= 2 ? review.AuthorName[..2].ToUpper() : review.AuthorName.ToUpper())</span>
                                    </div>
                                </div>
                                <div>
                                    <p class="text-white font-semibold text-sm">@review.AuthorName</p>
                                    <p class="text-yellow-400 text-xs">@string.Concat(Enumerable.Repeat("⭐", review.Rating)) @review.Rating.ToString("0.0")</p>
                                </div>
                            </div>
                            <p class="text-gray-400 text-sm">@review.Comment</p>
                        </div>
                    }
                </div>
            </div>

        </div>

        @* PRAWA STRONA - sticky panel *@
        <div class="lg:w-96">
            <div class="card bg-black border border-gray-800 rounded-xl overflow-hidden sticky top-4">
                
                @* OBRAZEK *@
                <div class="aspect-video overflow-hidden">
                    <img src=@course.ImageUrl 
                         class="w-full h-full object-cover" />
                </div>

                <div class="p-6">
                    <p class="text-white text-3xl font-bold mb-4">@course.Price.ToString("0.00") PLN</p>
                    @if (Model.IsPurchased)
                    {
                        <a href="/MyVault" class="btn bg-green-600 text-white rounded-full w-full font-bold mb-3 cursor-default">
                            ✓ Already Purchased
                        </a>
                    }
                    else if (Model.IsInCart)
                    {
                        <a href="/Cart" class="btn bg-gray-700 text-white rounded-full w-full font-bold mb-3">
                            ✓ Go to Cart
                        </a>
                    }
                    else
                    {
                        <form method="post" action="/Cart/Add">
                            <input type="hidden" name="idCourse" value="@course.IdCourse" />
                            <input type="hidden" name="returnUrl" value="/Courses/Detail/@course.IdCourse" />
                            <button type="submit" class="btn bg-white text-black rounded-full w-full font-bold hover:bg-gray-200 mb-3">
                                Add to Cart
                            </button>
                        </form>
                    }

                    @if (Model.IsInWishlist)
                    {
                        <form method="post" action="/Wishlist/Remove">
                            <input type="hidden" name="idCourse" value="@course.IdCourse" />
                            <button type="submit" class="btn bg-red-900 text-white border-red-800 rounded-full w-full hover:bg-red-800 mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                                </svg>
                                Remove from Wishlist
                            </button>
                        </form>
                    }
                    else
                    {
                        <form method="post" action="/Wishlist/Add">
                            <input type="hidden" name="idCourse" value="@course.IdCourse" />
                            <input type="hidden" name="returnUrl" value="/Courses/Detail/@course.IdCourse" />
                            <button type="submit" class="btn bg-black text-white border-gray-700 rounded-full w-full hover:bg-white hover:text-black mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                                </svg>
                                Add to Wishlist
                            </button>
                        </form>
                    }
                    <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800 my-2"></div>
                    <div class="flex flex-col gap-2 text-gray-400 text-sm">
                        <div class="flex justify-between">
                            <span>Category</span>
                            <span class="text-white">@course.CategoryName</span>
                        </div>
                        <div class="flex justify-between">
                            <span>Rating</span>
                            <span class="text-white">@course.AverageRating.ToString("0.0") ⭐</span>
                        </div>
                        <div class="flex justify-between">
                            <span>Sales</span>
                            <span class="text-white">@course.SalesCount</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>