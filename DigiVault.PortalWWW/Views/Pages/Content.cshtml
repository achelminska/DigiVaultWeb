@model DigiVault.PortalWWW.Models.CmsPageViewModel
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<article class="animate-fade-up mx-auto max-w-3xl py-10">
    <h1 class="font-display text-3xl font-extrabold text-white sm:text-4xl">@Model.Title</h1>
    <div class="mt-4 h-1 w-16 rounded-full bg-gradient-to-r from-violet-600 to-fuchsia-600"></div>
    <p class="mt-8 whitespace-pre-line leading-relaxed text-zinc-400">@Model.Content</p>
</article>
