@model AccountViewModel
@{
    ViewData["Title"] = "My Account";
    Layout = "_Layout";
    var p = Model.Profile;
}

<section class="py-6">
    <h1 class="text-white text-4xl font-bold mb-6">My Account</h1>

    <div role="tablist" class="tabs tabs-bordered mb-8">

        @* ── PROFILE TAB ─────────────────────────────────────────── *@
        <input type="radio" name="account_tabs" role="tab" class="tab text-white" aria-label="Profile" checked />
        <div role="tabpanel" class="tab-content pt-6">
            <div class="flex flex-col lg:flex-row gap-8">
                <div class="flex-1">

                    <h2 class="text-white text-xl font-bold mb-4">Personal Information</h2>
                    <form method="post" action="/Account/UpdateName" class="flex flex-col gap-4">
                        <div class="flex flex-col gap-1">
                            <label class="text-gray-400 text-sm">First Name</label>
                            <input type="text" name="firstName" value="@p.FirstName" class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-gray-400 text-sm">Last Name</label>
                            <input type="text" name="lastName" value="@p.LastName" class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                        </div>
                        <button type="submit" class="btn bg-white text-black rounded-full w-fit px-8 hover:bg-gray-200">Save Changes</button>
                    </form>

                    <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800 my-6"></div>

                    <h2 class="text-white text-xl font-bold mb-4">Email</h2>
                    <form method="post" action="/Account/UpdateEmail" class="flex flex-col gap-4">
                        <div class="flex flex-col gap-1">
                            <label class="text-gray-400 text-sm">New Email</label>
                            <input type="email" name="email" value="@p.Email" class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-gray-400 text-sm">Confirm with Password</label>
                            <input type="password" name="password" placeholder="••••••••" class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                        </div>
                        <button type="submit" class="btn bg-white text-black rounded-full w-fit px-8 hover:bg-gray-200">Update Email</button>
                    </form>

                    <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800 my-6"></div>

                    <h2 class="text-white text-xl font-bold mb-4">Change Password</h2>
                    <form method="post" action="/Account/UpdatePassword" class="flex flex-col gap-4">
                        <div class="flex flex-col gap-1">
                            <label class="text-gray-400 text-sm">Current Password</label>
                            <input type="password" name="password" placeholder="••••••••" class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-gray-400 text-sm">New Password</label>
                            <input type="password" name="newPassword" placeholder="••••••••" class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-gray-400 text-sm">Confirm New Password</label>
                            <input type="password" name="newPasswordConfirmation" placeholder="••••••••" class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                        </div>
                        <button type="submit" class="btn bg-white text-black rounded-full w-fit px-8 hover:bg-gray-200">Change Password</button>
                    </form>
                </div>
            </div>
        </div>

        @* ── MY COURSES TAB ───────────────────────────────────────── *@
        <input type="radio" name="account_tabs" role="tab" class="tab text-white" aria-label="My Courses" />
        <div role="tabpanel" class="tab-content pt-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-white text-xl font-bold">My Courses</h2>
                <a href="/Account/CourseForm" class="btn bg-white text-black rounded-full btn-sm px-6 hover:bg-gray-200">+ Add Course</a>
            </div>

            @if (!Model.MyCourses.Any())
            {
                <p class="text-gray-400">You haven't created any courses yet.</p>
            }
            else
            {
                <div class="flex flex-col gap-2">
                    @foreach (var course in Model.MyCourses)
                    {
                        <div class="flex gap-4 items-center py-4 border-b border-gray-800 px-2">
                            <img src="@(course.ImageUrl ?? "https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=400")"
                                 class="w-24 h-16 object-cover rounded-lg flex-shrink-0" />
                            <div class="flex-1">
                                <h3 class="text-white font-semibold text-sm">@course.Title</h3>
                                <p class="text-gray-400 text-xs mt-1">@course.CategoryName • @course.Price.ToString("F2") PLN</p>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="badge @(course.IsActive ? "badge-success" : "badge-error") badge-sm">@(course.IsActive ? "Active" : "Inactive")</span>
                                        <span class="text-gray-400 text-xs">@course.SalesCount sales</span>
                                    </div>
                                </div>
                                <button onclick="toggleVisibility(this, @course.IdCourse, @course.IsVisible.ToString().ToLower())"
                                        data-visible="@course.IsVisible.ToString().ToLower()"
                                        class="btn btn-circle btn-sm border transition-colors @(course.IsVisible ? "bg-black text-green-500 border-green-600 hover:bg-green-600 hover:text-black hover:border-green-600" : "bg-black text-gray-500 border-gray-600 hover:bg-white hover:text-black hover:border-white")">
                                    @if (course.IsVisible)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
                                    }
                                </button>
                                <a href="/Account/EditCourse/@course.IdCourse" class="btn btn-circle btn-sm bg-black text-white border border-gray-600 hover:bg-white hover:text-black hover:border-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                    </svg>
                                </a>
                            </div>
                    }
                </div>
            }
        </div>

        @* ── EARNINGS TAB ─────────────────────────────────────────── *@
        <input type="radio" name="account_tabs" role="tab" class="tab text-white" aria-label="Earnings" />
        <div role="tabpanel" class="tab-content pt-6">
            <h2 class="text-white text-xl font-bold mb-6">Earnings</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                <div class="card bg-black border border-gray-800 rounded-xl p-6">
                    <p class="text-gray-400 text-sm mb-1">Balance</p>
                    <p class="text-white text-3xl font-bold">@p.Balance.ToString("F2") PLN</p>
                </div>
                <div class="card bg-black border border-gray-800 rounded-xl p-6">
                    <p class="text-gray-400 text-sm mb-1">Total Withdrawn</p>
                    <p class="text-white text-3xl font-bold">@p.TotalWithdrawn.ToString("F2") PLN</p>
                </div>
            </div>
        </div>

    </div>
</section>

<script>
const eyeOpen = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>`;
const eyeClosed = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"></path><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>`;

async function toggleVisibility(btn, id, isVisible) {
    await fetch(`/Account/ToggleCourseVisibility`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `id=${id}&isVisible=${isVisible}`
    });

    const nowVisible = !isVisible;
    btn.dataset.visible = nowVisible;
    btn.innerHTML = nowVisible ? eyeOpen : eyeClosed;

    if (nowVisible) {
        btn.className = 'btn btn-circle btn-sm border transition-colors bg-black text-green-500 border-green-600 hover:bg-green-600 hover:text-black hover:border-green-600';
        btn.setAttribute('onclick', `toggleVisibility(this, ${id}, true)`);
    } else {
        btn.className = 'btn btn-circle btn-sm border transition-colors bg-black text-gray-500 border-gray-600 hover:bg-white hover:text-black hover:border-white';
        btn.setAttribute('onclick', `toggleVisibility(this, ${id}, false)`);
    }
}
</script>
