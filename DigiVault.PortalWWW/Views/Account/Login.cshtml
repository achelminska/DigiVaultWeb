@model DigiVault.PortalWWW.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" data-theme="black">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - DigiVault</title>
    <link rel="icon" type="image/png" href="/images/logoDV-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
                        display: ['Sora', 'Inter', 'sans-serif'],
                    },
                    colors: {
                        ink: { 950: '#0b0b11', 900: '#12121a', 800: '#1a1a24' },
                        brand: { 300: '#c4b5fd', 400: '#a78bfa', 500: '#8b5cf6', 600: '#7c3aed' },
                    },
                },
            },
        };
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.21.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</head>
<body class="auth-login-page font-sans antialiased">

<div class="relative flex min-h-screen items-center justify-center overflow-hidden px-4 py-12">
    <div class="auth-glow auth-glow-violet pointer-events-none absolute -top-40 left-1/2 h-96 w-[40rem] -translate-x-1/2 rounded-full bg-violet-600/20 blur-3xl"></div>
    <div class="auth-glow auth-glow-fuchsia pointer-events-none absolute -bottom-40 right-0 h-80 w-96 rounded-full bg-fuchsia-600/10 blur-3xl"></div>

    <div class="animate-fade-up relative w-full max-w-md">

        <div class="mb-8 flex justify-center">
            <a href="/"><img src="~/images/logoDV.png" alt="DigiVault" asp-append-version="true" class="auth-logo" /></a>
        </div>

        <div class="rounded-3xl border border-white/[0.08] bg-ink-900/90 p-8 shadow-2xl shadow-black/50 backdrop-blur-xl">
            <h1 class="font-display text-center text-2xl font-bold text-white">Welcome back</h1>
            <p class="mt-1.5 text-center text-sm text-zinc-500">Log in to continue learning</p>

            <form asp-controller="Account" asp-action="Login" method="post" class="mt-8 flex flex-col gap-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="rounded-xl border border-rose-500/30 bg-rose-500/10 px-4 py-3 text-center text-sm text-rose-300">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div>
                    <label class="mb-1.5 block text-xs font-medium text-zinc-400" for="Login">Login</label>
                    <input asp-for="Login" type="text" placeholder="Your login" class="input-dv" />
                    <span asp-validation-for="Login" class="mt-1 block text-xs text-rose-400"></span>
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-medium text-zinc-400" for="Password">Password</label>
                    <input asp-for="Password" type="password" placeholder="••••••••" class="input-dv" />
                    <span asp-validation-for="Password" class="mt-1 block text-xs text-rose-400"></span>
                </div>

                <button type="submit" class="btn btn-gradient mt-2 w-full rounded-full text-base font-bold">
                    Log in
                </button>
            </form>

            <p class="mt-6 text-center text-sm text-zinc-500">
                Don't have an account?
                <a href="/account/register" class="font-semibold text-brand-300 hover:text-brand-400 hover:underline">Sign up</a>
            </p>
        </div>

        <p class="mt-6 text-center text-xs text-zinc-600">
            <a href="/" class="transition-colors hover:text-zinc-400">← Back to DigiVault</a>
        </p>
    </div>
</div>
</body>
</html>
