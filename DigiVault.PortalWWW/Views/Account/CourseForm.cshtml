@model List<DigiVault.PortalWWW.Models.CategoryDto>
@{
    ViewData["Title"] = "Add Course";
    Layout = "_Layout";
}

<section class="py-6 mb-20">
    <h1 class="text-white text-4xl font-bold mb-6">Add Course</h1>

    <div class="flex flex-col lg:flex-row gap-8">

        <div class="flex-1">
            <form method="post" action="/Account/CreateCourse" id="courseForm" class="flex flex-col gap-4">

                <div class="flex flex-col gap-1">
                    <label class="text-gray-400 text-sm">Title</label>
                    <input type="text" name="title" id="titleInput" placeholder="Course title..."
                           class="input bg-black text-white border-gray-700 rounded-lg w-full" required />
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-gray-400 text-sm">Description</label>
                    <textarea name="description" placeholder="Course description..."
                              class="textarea bg-black text-white border-gray-700 rounded-lg w-full h-32" required></textarea>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-gray-400 text-sm">Category</label>
                    <select name="idCategory" class="select bg-black text-white border-gray-700 rounded-lg w-full" required>
                        <option value="" disabled selected>Select category</option>
                        @foreach (var cat in Model)
                        {
                            <option value="@cat.IdCategory">@cat.Name</option>
                        }
                    </select>
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-gray-400 text-sm">Price (PLN)</label>
                    <input type="number" name="price" step="0.01" min="0" placeholder="0.00"
                           class="input bg-black text-white border-gray-700 rounded-lg w-full" required />
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-gray-400 text-sm">Image URL</label>
                    <input type="url" name="imageUrl" id="imageInput" placeholder="https://..."
                           class="input bg-black text-white border-gray-700 rounded-lg w-full" />
                </div>

                <div class="flex gap-3 mt-4">
                    <button type="submit" class="btn bg-white text-black rounded-full px-8 hover:bg-gray-200 font-bold">
                        Save Course
                    </button>
                    <a href="/account" class="btn bg-black text-white border-gray-700 rounded-full px-8 hover:bg-white hover:text-black">
                        Cancel
                    </a>
                </div>

            </form>
        </div>

        @* PODGLĄD *@
        <div class="lg:w-80">
            <div class="card bg-black border border-gray-800 rounded-xl overflow-hidden sticky top-4">
                <div class="aspect-video bg-gray-900 flex items-center justify-center overflow-hidden">
                    <img id="previewImg" src="" alt="" class="w-full h-full object-cover hidden" />
                    <p id="previewPlaceholder" class="text-gray-600 text-sm">Image preview</p>
                </div>
                <div class="p-4">
                    <p id="previewTitle" class="text-gray-500 text-sm">Course title will appear here</p>
                </div>
            </div>
        </div>

    </div>
</section>

<script>
    document.getElementById('imageInput').addEventListener('input', function () {
        const img = document.getElementById('previewImg');
        const placeholder = document.getElementById('previewPlaceholder');
        if (this.value) {
            img.src = this.value;
            img.classList.remove('hidden');
            placeholder.classList.add('hidden');
        } else {
            img.classList.add('hidden');
            placeholder.classList.remove('hidden');
        }
    });

    document.getElementById('titleInput').addEventListener('input', function () {
        document.getElementById('previewTitle').textContent = this.value || 'Course title will appear here';
        document.getElementById('previewTitle').className = this.value ? 'text-white font-semibold text-sm' : 'text-gray-500 text-sm';
    });
</script>
