@model List<DigiVault.PortalWWW.Models.CategoryDto>
@{
    ViewData["Title"] = "Add Course";
    Layout = "_Layout";
}

<section class="animate-fade-up py-4 mb-16">
    <h1 class="font-display text-3xl font-extrabold text-white sm:text-4xl">Add Course</h1>
    <p class="mt-2 text-zinc-500">Share what you know — publish a new course on the marketplace</p>

    <div class="mt-8 flex flex-col gap-8 lg:flex-row">

        <div class="min-w-0 flex-1">
            <form method="post" action="/Account/CreateCourse" id="courseForm"
                  class="flex flex-col gap-5 rounded-2xl border border-white/[0.08] bg-ink-900 p-6">

                <div>
                    <label class="mb-1.5 block text-xs font-medium text-zinc-400">Title</label>
                    <input type="text" name="title" id="titleInput" placeholder="Course title…" class="input-dv" required />
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-medium text-zinc-400">Description</label>
                    <textarea name="description" placeholder="What will students learn?" rows="5"
                              class="input-dv resize-y" required></textarea>
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-medium text-zinc-400">Category</label>
                    <input type="hidden" name="idCategory" id="categoryInput" required />
                    <div class="relative w-full" id="categoryDropdown">
                        <button type="button" onclick="toggleDropdown()"
                                class="input-dv flex items-center justify-between text-left">
                            <span id="categoryLabel" class="text-zinc-500">Select category</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-500"><path d="m6 9 6 6 6-6"/></svg>
                        </button>
                        <ul id="categoryList" class="absolute z-50 mt-2 hidden max-h-60 w-full overflow-y-auto rounded-xl border border-white/10 bg-ink-800 p-1.5 shadow-2xl">
                            @foreach (var cat in Model)
                            {
                                <li onclick="selectCategory(@cat.IdCategory, '@cat.Name')"
                                    class="cursor-pointer rounded-lg px-3.5 py-2 text-sm text-zinc-300 transition-colors hover:bg-brand-500/15 hover:text-white">
                                    @cat.Name
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
                    <div>
                        <label class="mb-1.5 block text-xs font-medium text-zinc-400">Price (PLN)</label>
                        <input type="number" name="price" step="0.01" min="0" placeholder="0.00" class="input-dv" required />
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-medium text-zinc-400">Image URL</label>
                        <input type="url" name="imageUrl" id="imageInput" placeholder="https://…" class="input-dv" />
                    </div>
                </div>

                <div class="mt-2 flex gap-3">
                    <button type="submit" class="btn btn-gradient rounded-full px-8 font-bold">
                        Publish Course
                    </button>
                    <a href="/account" class="btn rounded-full border border-white/15 bg-transparent px-8 font-semibold text-zinc-300 hover:border-white/40 hover:bg-white/5 hover:text-white">
                        Cancel
                    </a>
                </div>
            </form>
        </div>

        @* live preview *@
        <div class="w-full lg:w-80 lg:shrink-0">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-zinc-600">Live preview</p>
            <div class="sticky top-24 overflow-hidden rounded-2xl border border-white/[0.08] bg-ink-900">
                <div class="flex aspect-video items-center justify-center overflow-hidden bg-ink-800">
                    <img id="previewImg" src="" alt="" class="hidden h-full w-full object-cover" />
                    <p id="previewPlaceholder" class="text-sm text-zinc-600">Image preview</p>
                </div>
                <div class="p-4">
                    <p id="previewTitle" class="text-sm text-zinc-600">Course title will appear here</p>
                </div>
            </div>
        </div>

    </div>
</section>

<script>
    function toggleDropdown() {
        document.getElementById('categoryList').classList.toggle('hidden');
    }
    function selectCategory(id, name) {
        document.getElementById('categoryInput').value = id;
        document.getElementById('categoryLabel').textContent = name;
        document.getElementById('categoryLabel').className = 'text-white';
        document.getElementById('categoryList').classList.add('hidden');
    }
    document.addEventListener('click', function(e) {
        if (!document.getElementById('categoryDropdown').contains(e.target))
            document.getElementById('categoryList').classList.add('hidden');
    });

    document.getElementById('imageInput').addEventListener('input', function () {
        const img = document.getElementById('previewImg');
        const placeholder = document.getElementById('previewPlaceholder');
        if (this.value) {
            img.src = this.value;
            img.classList.remove('hidden');
            placeholder.classList.add('hidden');
        } else {
            img.classList.add('hidden');
            placeholder.classList.remove('hidden');
        }
    });

    document.getElementById('titleInput').addEventListener('input', function () {
        document.getElementById('previewTitle').textContent = this.value || 'Course title will appear here';
        document.getElementById('previewTitle').className = this.value ? 'text-sm font-semibold text-white' : 'text-sm text-zinc-600';
    });
</script>
