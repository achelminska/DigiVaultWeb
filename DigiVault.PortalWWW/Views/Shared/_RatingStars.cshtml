@model (double Rating, int Count)
@{
    // width of the filled overlay as a percentage of 5 stars
    var percent = Math.Clamp(Model.Rating / 5.0 * 100, 0, 100);
}
<div class="flex items-center gap-1.5">
    <span class="text-xs font-semibold text-amber-400">@Model.Rating.ToString("0.0")</span>
    <div class="relative inline-block leading-none" aria-label="@Model.Rating.ToString("0.0") out of 5 stars">
        <div class="text-[11px] tracking-tight text-zinc-700 select-none">★★★★★</div>
        <div class="absolute inset-0 overflow-hidden whitespace-nowrap text-[11px] tracking-tight text-amber-400 select-none" style="width: @(percent.ToString("0", System.Globalization.CultureInfo.InvariantCulture))%">★★★★★</div>
    </div>
    @if (Model.Count > 0)
    {
        <span class="text-xs text-zinc-500">(@Model.Count)</span>
    }
</div>
