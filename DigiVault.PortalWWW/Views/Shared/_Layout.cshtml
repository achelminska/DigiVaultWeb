<!DOCTYPE html>
<html lang="en" data-theme="black">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DigiVault</title>
    <meta name="description" content="DigiVault — a digital course marketplace. Browse, buy and sell online courses." />
    <link rel="icon" type="image/png" href="/images/logoDV-icon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@600;700;800&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/daisyui@4.12.10/dist/full.min.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
                        display: ['Sora', 'Inter', 'sans-serif'],
                    },
                    colors: {
                        ink: { 950: '#0b0b11', 900: '#12121a', 800: '#1a1a24', 700: '#242430' },
                        brand: { 300: '#c4b5fd', 400: '#a78bfa', 500: '#8b5cf6', 600: '#7c3aed' },
                    },
                },
            },
        };
    </script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="~/js/site.js" asp-append-version="true" defer></script>
</head>
<body class="min-h-screen flex flex-col font-sans text-zinc-300 antialiased">

@{ var isLoggedIn = Context.Session.GetString("Token") != null; }

@* ── NAVBAR ─────────────────────────────────────────────── *@
<header class="sticky top-0 z-50 border-b border-white/[0.06] bg-ink-950/80 backdrop-blur-xl">
    <div class="mx-auto flex h-16 max-w-7xl items-center gap-4 px-4 lg:px-8">

        <a href="/" class="flex shrink-0 items-center gap-2.5 group">
            <img src="~/images/logoDV.png" alt="DigiVault" asp-append-version="true" class="h-10 w-auto transition-transform duration-300 group-hover:scale-105" />
        </a>

        <nav class="hidden lg:flex items-center gap-1 ml-4 text-sm font-medium">
            <a href="/courses" class="rounded-lg px-3 py-2 text-zinc-400 transition-colors hover:text-white hover:bg-white/5">Explore</a>
            @if (isLoggedIn)
            {
                <a href="/myvault" class="rounded-lg px-3 py-2 text-zinc-400 transition-colors hover:text-white hover:bg-white/5">My Vault</a>
                <a href="/wishlist" class="rounded-lg px-3 py-2 text-zinc-400 transition-colors hover:text-white hover:bg-white/5">Wishlist</a>
            }
        </nav>

        <form action="/courses" method="get" class="hidden md:flex flex-1 justify-center px-4">
            <label class="flex w-full max-w-md items-center gap-2.5 rounded-full border border-white/10 bg-white/5 px-4 py-2 transition-colors focus-within:border-brand-400/60 focus-within:bg-white/[0.08]">
                <svg class="h-4 w-4 shrink-0 text-zinc-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                </svg>
                <input type="search" name="search" placeholder="Search courses…"
                       class="w-full bg-transparent text-sm text-white placeholder-zinc-500 outline-none" />
            </label>
        </form>

        <div class="ml-auto flex items-center gap-1.5">
            @if (isLoggedIn)
            {
                <div class="relative">
                    @await Component.InvokeAsync("CartCount")
                    <a href="/cart" aria-label="Cart"
                       class="flex h-10 w-10 items-center justify-center rounded-full text-zinc-400 transition-colors hover:bg-white/5 hover:text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/>
                            <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>
                        </svg>
                    </a>
                </div>

                <a href="/account" class="hidden lg:flex h-10 items-center gap-2 rounded-full px-3 text-sm font-medium text-zinc-400 transition-colors hover:bg-white/5 hover:text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                    </svg>
                    Account
                </a>

                <a href="/account/logout" class="hidden lg:inline-flex h-9 items-center rounded-full border border-white/10 px-4 text-sm font-medium text-zinc-300 transition-colors hover:border-white/25 hover:text-white">
                    Logout
                </a>
            }
            else
            {
                <a href="/account/login" class="hidden lg:inline-flex h-9 items-center rounded-full px-4 text-sm font-medium text-zinc-300 transition-colors hover:text-white">
                    Log in
                </a>
                <a href="/account/register" class="hidden lg:inline-flex h-9 items-center rounded-full bg-gradient-to-r from-violet-600 to-fuchsia-600 px-4 text-sm font-semibold text-white transition-opacity hover:opacity-90">
                    Sign up
                </a>
            }

            @* mobile menu *@
            <div class="dropdown dropdown-end lg:hidden">
                <label tabindex="0" aria-label="Menu" class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full text-zinc-300 transition-colors hover:bg-white/5">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                </label>
                <ul tabindex="0" class="menu dropdown-content z-[60] mt-3 w-56 rounded-2xl border border-white/10 bg-ink-900 p-2 shadow-2xl">
                    <li><a href="/courses" class="text-zinc-300">Explore</a></li>
                    @if (isLoggedIn)
                    {
                        <li><a href="/myvault" class="text-zinc-300">My Vault</a></li>
                        <li><a href="/wishlist" class="text-zinc-300">Wishlist</a></li>
                        <li><a href="/cart" class="text-zinc-300">Cart</a></li>
                        <li><a href="/account" class="text-zinc-300">Account</a></li>
                        <li><a href="/account/logout" class="text-zinc-300">Logout</a></li>
                    }
                    else
                    {
                        <li><a href="/account/login" class="text-zinc-300">Log in</a></li>
                        <li><a href="/account/register" class="text-zinc-300">Sign up</a></li>
                    }
                </ul>
            </div>
        </div>
    </div>
</header>

<main class="mx-auto w-full max-w-7xl flex-1 px-4 py-8 lg:px-8">
    @RenderBody()
</main>

@* ── FOOTER ─────────────────────────────────────────────── *@
<footer class="border-t border-white/[0.06] bg-ink-950/60">
    <div class="mx-auto max-w-7xl px-4 py-12 lg:px-8">
        <div class="flex flex-col gap-10 md:flex-row md:justify-between">
            <div class="max-w-xs">
                <img src="~/images/logoDV.png" alt="DigiVault" asp-append-version="true" class="h-10 w-auto mb-4" />
                <p class="text-sm leading-relaxed text-zinc-500">
                    A digital marketplace for online courses. Learn something new — or share what you know and earn.
                </p>
            </div>
            <div class="flex gap-16">
                <div>
                    <h3 class="mb-3 text-xs font-semibold uppercase tracking-widest text-zinc-500">Marketplace</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/courses" class="text-zinc-400 transition-colors hover:text-white">Browse Courses</a></li>
                        <li><a href="/myvault" class="text-zinc-400 transition-colors hover:text-white">My Vault</a></li>
                        <li><a href="/wishlist" class="text-zinc-400 transition-colors hover:text-white">Wishlist</a></li>
                    </ul>
                </div>
                <div>
                    <h3 class="mb-3 text-xs font-semibold uppercase tracking-widest text-zinc-500">Company</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/pages/about" class="text-zinc-400 transition-colors hover:text-white">About</a></li>
                        <li><a href="/pages/terms" class="text-zinc-400 transition-colors hover:text-white">Terms</a></li>
                        <li><a href="/pages/privacy" class="text-zinc-400 transition-colors hover:text-white">Privacy</a></li>
                        <li><a href="/pages/contact" class="text-zinc-400 transition-colors hover:text-white">Contact</a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="mt-10 border-t border-white/[0.06] pt-6 text-center text-xs text-zinc-600">
            @await Component.InvokeAsync("CmsFooter")
        </div>
    </div>
</footer>

@RenderSection("Scripts", required: false)
</body>
</html>
