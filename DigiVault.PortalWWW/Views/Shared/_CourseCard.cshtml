@model DigiVault.PortalWWW.Models.CourseListDto

<a asp-controller="Courses" asp-action="Detail" asp-route-id="@Model.IdCourse" class="block h-full">
    <article class="dv-card flex h-full flex-col overflow-hidden rounded-2xl border border-white/[0.08] bg-ink-900">
        <div class="dv-thumb relative aspect-[16/10] overflow-hidden bg-ink-800">
            <img src="@(Model.ImageUrl ?? "https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=600")"
                 alt="@Model.Title" loading="lazy" class="h-full w-full object-cover" />
            @if (!string.IsNullOrEmpty(Model.CategoryName))
            {
                <span class="absolute left-3 top-3 rounded-full bg-black/60 px-3 py-1 text-[11px] font-medium text-zinc-200 backdrop-blur-sm">
                    @Model.CategoryName
                </span>
            }
        </div>
        <div class="flex flex-1 flex-col gap-1.5 p-4">
            <h3 class="line-clamp-2 text-sm font-semibold leading-snug text-white">@Model.Title</h3>
            <p class="text-xs text-zinc-500">@Model.AuthorName</p>
            @await Html.PartialAsync("_RatingStars", (Model.AverageRating, Model.RatingsCount))
            <p class="mt-auto pt-2 text-base font-bold text-white">@Model.Price.ToString("0.00") <span class="text-xs font-medium text-zinc-500">PLN</span></p>
        </div>
    </article>
</a>
