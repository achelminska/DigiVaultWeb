@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="animate-fade-up flex flex-col items-center py-24 text-center">
    <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full border border-rose-500/30 bg-rose-500/10 text-rose-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>
        </svg>
    </div>
    <h1 class="font-display text-3xl font-extrabold text-white">Something went wrong</h1>
    <p class="mt-3 max-w-md text-zinc-500">An unexpected error occurred while processing your request. Please try again in a moment.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-4 rounded-full border border-white/10 bg-white/[0.04] px-4 py-1.5 text-xs text-zinc-500">
            Request ID: <code class="text-zinc-400">@Model.RequestId</code>
        </p>
    }

    <a href="/" class="btn btn-gradient mt-8 rounded-full px-8 font-semibold">Back to Home</a>
</section>
