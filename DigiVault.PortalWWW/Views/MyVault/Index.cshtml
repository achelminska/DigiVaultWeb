@model List<DigiVault.PortalWWW.Models.CourseListDto>
@{
    ViewData["Title"] = "My Vault";
    Layout = "_Layout";
}

<section class="py-6">
    <h1 class="text-white text-4xl font-bold mb-6">My Vault</h1>
</section>

<section class="mb-20">
    @if (!Model.Any())
    {
        <div class="text-center py-20">
            <p class="text-gray-400 text-lg">You haven't purchased any courses yet.</p>
            <a href="/Courses" class="btn bg-black text-white border border-white rounded-full mt-4 hover:bg-white hover:text-black transition-colors">Browse Courses</a>
        </div>
    }
    else
    {
        <p class="text-gray-400 text-sm mb-4">@Model.Count course@(Model.Count != 1 ? "s" : "")</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            @foreach (var course in Model)
            {
                <div class="card bg-black hover:scale-105 transition-transform cursor-pointer border border-gray-800 rounded-lg">
                    <a href="/Courses/Detail/@course.IdCourse">
                        <figure>
                            <img src="@(course.ImageUrl ?? "https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=400")"
                                 class="w-full h-40 object-cover" />
                        </figure>
                    </a>
                    <div class="card-body p-4">
                        <h3 class="card-title text-white text-sm">@course.Title</h3>
                        <p class="text-gray-400 text-xs">@course.AuthorName</p>
                        @await Html.PartialAsync("_RatingStars", (course.AverageRating, course.RatingsCount))
                        <div class="flex justify-end mt-2">
                            <a href="/Courses/Detail/@course.IdCourse"
                               class="btn btn-circle bg-black text-white border border-white hover:bg-white hover:text-black transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="transform:translateX(2px)">
                                        <path d="M7.05 3.606c-1.18-.7-2.65.188-2.65 1.545v13.698c0 1.357 1.47 2.245 2.65 1.545l11.9-6.849c1.15-.661 1.15-2.429 0-3.09L7.05 3.606z"/>
                                    </svg>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>
