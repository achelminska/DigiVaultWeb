@model List<DigiVault.PortalWWW.Models.CourseListDto>
@{
    ViewData["Title"] = "My Vault";
    Layout = "_Layout";
}

<section class="py-6">
    <h1 class="text-white text-4xl font-bold mb-6">My Vault</h1>
</section>

<section class="mb-20">
    @if (!Model.Any())
    {
        <div class="text-center py-20">
            <p class="text-gray-400 text-lg">You haven't purchased any courses yet.</p>
            <a href="/Courses" class="btn bg-white text-black rounded-full mt-4">Browse Courses</a>
        </div>
    }
    else
    {
        <p class="text-gray-400 text-sm mb-4">@Model.Count course@(Model.Count != 1 ? "s" : "")</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            @foreach (var course in Model)
            {
                <div class="card bg-black hover:scale-105 transition-transform cursor-pointer border border-gray-800 rounded-lg">
                    <a href="/Courses/Detail/@course.IdCourse">
                        <figure>
                            <img src="@(course.ImageUrl ?? "https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=400")"
                                 class="w-full h-40 object-cover" />
                        </figure>
                    </a>
                    <div class="card-body p-4">
                        <a href="/Courses/Detail/@course.IdCourse">
                            <h3 class="card-title text-white text-sm hover:underline">@course.Title</h3>
                        </a>
                        <p class="text-gray-400 text-xs">@course.AuthorName</p>
                        <div class="flex items-center gap-1 text-yellow-400 text-xs">
                            ⭐ @course.AverageRating.ToString("F1") <span class="text-gray-400">(@course.RatingsCount)</span>
                        </div>
                        <a href="/Courses/Detail/@course.IdCourse"
                           class="btn btn-sm rounded-full mt-2 bg-black border-gray-700 text-white hover:bg-white hover:text-black">
                            Continue Learning
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</section>
