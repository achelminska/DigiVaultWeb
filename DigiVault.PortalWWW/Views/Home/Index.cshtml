@model HomeViewModel

@{
    ViewData["Title"] = "Home";
    Layout = "_Layout";
    var popularCourses = Model.PopularCourses;
    var newestCourses = Model.NewestCourses;
    var topRatedCourses = Model.TopRatedCourses;
    var categories = Model.Categories;
}

@* HERO *@
<section class="py-8">
    <h1 class="text-white text-4xl font-bold mb-2">@Model.HeroTitle</h1>
    <p class="text-gray-400 text-lg mb-4">@Model.HeroSubtitle</p>
    <p class="text-gray-500 text-sm">Hello, <span class="text-white">@Model.HeroTest</span></p>
</section>

@* MOST POPULAR *@
<section class="py-4">
    <h2 class="text-white text-2xl font-bold mb-4">Most Popular</h2>
    <div class="relative">
        
        @* PRZYCISK LEWO *@
        <button onclick="scrollCarouselLeft('popular')" 
                class="absolute left-0 top-1/2 -translate-y-1/2 z-10 btn btn-circle bg-black text-white border-gray-800 -ml-8 hover:bg-white hover:text-black hover:border-white">
            ❮
        </button>

        @* KARUZELA *@
        <div id="popular" class="flex gap-4 overflow-x-auto pb-4" style="scrollbar-width: none;">
            @* KARTA - powiel tyle razy ile kursów *@
        @foreach (var course in popularCourses)
        {
            <a asp-controller="Courses" asp-action="Detail" asp-route-id="@course.IdCourse">
            <div class="card bg-black min-w-[260px] max-w-[260px] hover:scale-105 transition-transform cursor-pointer border border-gray-800 rounded-lg flex-shrink-0" style="height: 320px;">
                <figure class="flex-shrink-0">
                    <img src="@course.ImageUrl" alt="@course.Title" class="w-full h-40 object-cover" />
                </figure>
                <div class="card-body p-4">
                    <h3 class="card-title text-white text-sm line-clamp-2">@course.Title</h3>
                    <p class="text-gray-400 text-xs">@course.AuthorName</p>
                    <div class="flex items-center gap-1 text-yellow-400 text-xs">
                        @await Html.PartialAsync("_RatingStars", (course.AverageRating, course.RatingsCount))
                    </div>
                    <p class="text-white font-bold mt-auto">@course.Price.ToString("0.00") PLN</p>
                </div>
            </div>
             </a>
        }

        </div>

        @* PRZYCISK PRAWO *@
        <button onclick="scrollCarouselRight('popular')" 
                class="absolute right-0 top-1/2 -translate-y-1/2 z-10 btn btn-circle bg-black text-white border-gray-800 -mr-8 hover:bg-white hover:text-black hover:border-white">
            ❯
        </button>
        
        
    </div>
</section>

@* CATEGORIES *@
<section class="py-4">
    <h2 class="text-white text-2xl font-bold mb-4">Categories</h2>
    <div class="flex flex-wrap gap-3">
        @foreach (var category in Model.Categories)
        {
            <a href="/Courses?idCategory=@category.IdCategory" class="badge badge-outline text-white border-gray-500 rounded-full px-4 py-3 cursor-pointer hover:bg-white hover:text-black hover:scale-105 transition-transform">@category.Name</a>
        }
    </div>
</section>

