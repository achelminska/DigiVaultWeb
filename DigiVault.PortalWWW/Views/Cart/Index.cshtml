@{
    ViewData["Title"] = "Cart";
    Layout = "_Layout";
}

<section class="py-6">
    <h1 class="text-white text-4xl font-bold">Cart</h1>
    <p class="text-gray-400 text-sm mt-2">3 courses</p>
</section>

<section class="mb-20">
    <div class="flex flex-col lg:flex-row gap-8">

        @* LISTA KURSÓW *@
        <div class="flex-1 flex flex-col gap-1">

            <div class="flex gap-4 items-center py-4 border-b border-gray-800 px-2">
                <img src="https://images.unsplash.com/photo-1526379095098-d400fd0bf935?w=400" 
                     class="w-24 h-16 object-cover rounded-lg flex-shrink-0" />
                <div class="flex-1">
                    <h3 class="text-white font-semibold text-sm">Vue.js 3 – Kompletny Przewodnik</h3>
                    <p class="text-gray-400 text-xs mt-1">Aleksandra Chełmińska</p>
                    <div class="flex items-center gap-1 text-yellow-400 text-xs mt-1">
                        ⭐ 4.5 <span class="text-gray-400">(95)</span>
                    </div>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <p class="text-white font-bold">159.99 PLN</p>
                    <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">Usuń</button>
                </div>
            </div>

            <div class="flex gap-4 items-center py-4 border-b border-gray-800 px-2">
                <img src="https://images.unsplash.com/photo-1555949963-ff9fe0c870eb?w=400" 
                     class="w-24 h-16 object-cover rounded-lg flex-shrink-0" />
                <div class="flex-1">
                    <h3 class="text-white font-semibold text-sm">Bezpieczeństwo Sieci Komputerowych</h3>
                    <p class="text-gray-400 text-xs mt-1">Aleksandra Chełmińska</p>
                    <div class="flex items-center gap-1 text-yellow-400 text-xs mt-1">
                        ⭐ 4.4 <span class="text-gray-400">(67)</span>
                    </div>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <p class="text-white font-bold">179.99 PLN</p>
                    <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">Usuń</button>
                </div>
            </div>

            <div class="flex gap-4 items-center py-4 border-b border-gray-800 px-2">
                <img src="https://images.unsplash.com/photo-1677442135703-1787eea5ce01?w=400" 
                     class="w-24 h-16 object-cover rounded-lg flex-shrink-0" />
                <div class="flex-1">
                    <h3 class="text-white font-semibold text-sm">C# – Programowanie Obiektowe</h3>
                    <p class="text-gray-400 text-xs mt-1">Aleksandra Chełmińska</p>
                    <div class="flex items-center gap-1 text-yellow-400 text-xs mt-1">
                        ⭐ 4.7 <span class="text-gray-400">(195)</span>
                    </div>
                </div>
                <div class="flex flex-col items-end gap-2">
                    <p class="text-white font-bold">139.99 PLN</p>
                    <button class="btn btn-ghost btn-xs text-red-500 hover:text-red-400">Usuń</button>
                </div>
            </div>

        </div>

        @* PODSUMOWANIE *@
        <div class="lg:w-80">
            <div class="card bg-black border border-gray-800 rounded-xl p-6 sticky top-4">
                <h2 class="text-white text-xl font-bold mb-4">Order Summary</h2>
                <div class="flex justify-between text-gray-400 text-sm mb-2">
                    <span>3 courses</span>
                    <span>478.97 PLN</span>
                </div>
                <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800 my-2"></div>
                <div class="flex justify-between text-white font-bold mb-6">
                    <span>Total</span>
                    <span>478.97 PLN</span>
                </div>
                <button class="btn bg-white text-black rounded-full w-full font-bold hover:bg-gray-200">
                    Checkout
                </button>
            </div>
        </div>

    </div>
</section>