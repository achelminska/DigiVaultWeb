@model List<DigiVault.PortalWWW.Models.CourseListDto>
@{
    ViewData["Title"] = "Cart";
    Layout = "_Layout";
    var total = Model.Sum(c => c.Price);
}

<section class="py-6">
    <h1 class="text-white text-4xl font-bold">Cart</h1>
    <p class="text-gray-400 text-sm mt-2">@Model.Count course@(Model.Count != 1 ? "s" : "")</p>
</section>

<section class="mb-20">
    @if (!Model.Any())
    {
        <div class="text-center py-20">
            <p class="text-gray-400 text-lg">Your cart is empty.</p>
            <a href="/Courses" class="btn bg-white text-black rounded-full mt-4">Browse Courses</a>
        </div>
    }
    else
    {
        <div class="flex flex-col lg:flex-row gap-8">
            <div class="flex-1 flex flex-col gap-1">
                @foreach (var course in Model)
                {
                    <div class="flex gap-4 items-center py-4 border-b border-gray-800 px-2">
                        <a href="/Courses/Detail/@course.IdCourse">
                            <img src="@(course.ImageUrl ?? "https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=400")"
                                 class="w-24 h-16 object-cover rounded-lg flex-shrink-0 hover:opacity-80 transition-opacity" />
                        </a>
                        <div class="flex-1">
                            <a href="/Courses/Detail/@course.IdCourse" class="text-white font-semibold text-sm hover:underline">@course.Title</a>
                            <p class="text-gray-400 text-xs mt-1">@course.AuthorName</p>
                            <div class="flex items-center gap-1 text-yellow-400 text-xs mt-1">
                                ⭐ @course.AverageRating.ToString("F1") <span class="text-gray-400">(@course.RatingsCount)</span>
                            </div>
                        </div>
                        <div class="flex flex-col items-end gap-2">
                            <p class="text-white font-bold">@course.Price.ToString("F2") PLN</p>
                            <form method="post" action="/Cart/Remove">
                                <input type="hidden" name="idCourse" value="@course.IdCourse" />
                                <button type="submit" class="btn btn-sm btn-circle bg-black border border-gray-700 text-red-500 hover:bg-red-950 hover:border-red-800 hover:text-red-400 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                        <path d="M10 11v6"></path><path d="M14 11v6"></path>
                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>

            <div class="lg:w-80">
                <div class="card bg-black border border-gray-800 rounded-xl p-6 sticky top-4">
                    <h2 class="text-white text-xl font-bold mb-4">Order Summary</h2>
                    <div class="flex justify-between text-gray-400 text-sm mb-2">
                        <span>@Model.Count course@(Model.Count != 1 ? "s" : "")</span>
                        <span>@total.ToString("F2") PLN</span>
                    </div>
                    <div class="divider divider-neutral before:bg-gray-800 after:bg-gray-800 my-2"></div>
                    <div class="flex justify-between text-white font-bold mb-6">
                        <span>Total</span>
                        <span>@total.ToString("F2") PLN</span>
                    </div>
                    <button class="btn bg-white text-black rounded-full w-full font-bold hover:bg-gray-200">
                        Checkout
                    </button>
                </div>
            </div>
        </div>
    }
</section>
